&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;sparql &lt;span style="color:#f92672"&gt;=&lt;/span&gt; SPARQLWrapper(&lt;span style="color:#e6db74"&gt;&amp;#34;https://query.wikidata.org/sparql&amp;#34;&lt;/span&gt;)
